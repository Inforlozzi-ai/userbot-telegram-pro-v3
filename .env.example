# ── Domínio e SSL (Traefik / Let's Encrypt) ─────────────────────────
DOMAIN=revendabot.expressvisto.com
ACME_EMAIL=inforlozzi@gmail.com

# ── Banco de dados ───────────────────────────────────────────────────
POSTGRES_USER=inforlozzi
POSTGRES_PASSWORD=TROQUE_AQUI
POSTGRES_DB=inforlozzi
DATABASE_URL=postgresql://inforlozzi:TROQUE_AQUI@postgres:5432/inforlozzi

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── JWT (gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=GERE_AQUI

# ── AES-256 (gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
CRYPTO_KEY=GERE_AQUI_64_CHARS_HEX

# ── Docker ─────────────────────────────────────────────────────────────────
DOCKER_IMAGE=inforlozzi/userbot-v3:latest

# ── Asaas ─────────────────────────────────────────────────────────────────
ASAAS_API_KEY=SUA_CHAVE_ASAAS
ASAAS_WEBHOOK_TOKEN=TOKEN_ALEATORIO
ASAAS_PLAN_STARTER=ID_PLANO_STARTER
ASAAS_PLAN_PRO=ID_PLANO_PRO
ASAAS_PLAN_AGENCY=ID_PLANO_AGENCY

# ── Notificações Telegram ───────────────────────────────────────────────
NOTIFY_BOT_TOKEN=TOKEN_DO_BOT_DE_NOTIFICACOES

# ── Next.js ─────────────────────────────────────────────────────────────────
INTERNAL_API_URL=http://api:3001
NEXT_PUBLIC_APP_URL=https://revendabot.expressvisto.com
