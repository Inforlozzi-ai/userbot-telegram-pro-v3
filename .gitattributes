# Git Attributes Configuration

# Auto detect text files and normalize line endings to LF
* text=auto

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Python
*.py text eol=lf
*.pyw text eol=lf

# Markdown
*.md text eol=lf
*.markdown text eol=lf

# Documentation
*.txt text eol=lf
*.rst text eol=lf

# Git config
.gitignore text eol=lf
.gitattributes text eol=lf

# License
LICENSE text eol=lf

# JSON
*.json text eol=lf

# YAML
*.yml text eol=lf
*.yaml text eol=lf

# Environment
.env text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.tar binary
*.tar.gz binary

# Session files
*.session binary
